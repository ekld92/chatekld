# ChatEKLD online provider configuration.
#
# At startup ChatEKLD loads a .env file from (in priority order):
#   1. ~/Library/Application Support/ChatEKLD/.env   <-- use this for the .app
#   2. a .env beside launch.py (dev convenience; ignored in the frozen .app)
# A real shell variable always wins over the file (override=False), so dev runs
# launched from a terminal keep using ~/.zshrc.
#
# IMPORTANT (packaged .app): a Finder-launched .app does NOT inherit your shell
# environment, so keys exported in ~/.zshrc are invisible to it. Put them in
#   ~/Library/Application Support/ChatEKLD/.env
# (copy this file there) so the bundle can read them.
#
# Never commit your real API keys. ChatEKLD never persists keys to
# config.json and the /api/config endpoint never returns them.

# OpenAI (gpt-4o, gpt-4o-mini, gpt-4.1, gpt-3.5-turbo, o1, o3-mini, ...).
# Default model selection: gpt-4o-mini.
# Get a key at https://platform.openai.com/account/api-keys
#OPENAI_API_KEY=sk-...
# Optional — point at a compatible endpoint (Azure, Together, ...).
#OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5,
# claude-3-5-sonnet, claude-3-5-haiku, ...). Default: claude-haiku-4-5.
# Get a key at https://console.anthropic.com/settings/keys
#ANTHROPIC_API_KEY=sk-ant-...
# Optional — override the base URL for self-hosted Anthropic compatibility.
#ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini (gemini-2.5-pro, gemini-2.5-flash, gemini-1.5-pro, ...).
# Default: gemini-2.5-flash.
# Get a key at https://aistudio.google.com/app/apikey
#GOOGLE_API_KEY=AIza...
# Optional — Vertex-style endpoint override.
#GOOGLE_BASE_URL=https://generativelanguage.googleapis.com
